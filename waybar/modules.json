		"exec": "~/.config/waybar/scripts/playerctl-mpris.sh",
		"interval": 2,
		"on-click": "~/.config/waybar/scripts/player.sh",
		"on-click-right": "~/.config/waybar/scripts/player-next.sh",
		"on-click-middle": "~/.config/waybar/scripts/player-prev.sh",
		"on-scroll-up": "~/.config/waybar/scripts/player-next.sh",
		"on-scroll-down": "~/.config/waybar/scripts/player-prev.sh",
		"escape": true,
		"format-icons": {
			"Playing": "ÔÄĀ",
			"Paused": "ÔĀč",
			"Stopped": "ÔĀĆ"
		}
	},
	"clock": {
